{
    "name": "avianvisitors/webui",
    "description": "AvianVisitors web UI backend and its test suite.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "ext-pdo": "*",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "AvianVisitors\\": "backend/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AvianVisitors\\Tests\\": "tests/php/",
            "AvianVisitors\\Tests\\Support\\": "tests/support/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
