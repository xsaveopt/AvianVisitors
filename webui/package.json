{
  "name": "avianvisitors",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite frontend",
    "build": "vue-tsc -b frontend && vite build frontend",
    "preview": "vite preview frontend",
    "typecheck": "vue-tsc -b frontend --noEmit",
    "lint": "oxlint frontend/src",
    "format": "oxfmt frontend/src/styles.css",
    "format:check": "oxfmt --check frontend/src/styles.css",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "test:unit": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.0.0"
  }
}
